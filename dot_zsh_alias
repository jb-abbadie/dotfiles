alias ls="eza -F --group-directories-first"
alias ll="ls -lh"
alias l="ll"

alias vim=nvim

alias kubectl="kubecolor"
alias k="kubectl"
alias ks="kubectl --sort-by='.metadata.creationTimestamp'"
alias t="terraform"
alias aws-profile='export AWS_PROFILE=$(aws configure list-profiles | fzf)'

alias gdc="git diff --cached"

alias watch="KUBECOLOR_FORCE_COLORS=truecolor watch "
alias viddy="KUBECOLOR_FORCE_COLORS=truecolor viddy "

# Use kitten ssh inside kitty so terminfo gets shipped to the remote
if [[ -n "$KITTY_WINDOW_ID" ]] && (( $+commands[kitten] )); then
  alias ssh="kitten ssh"
fi
