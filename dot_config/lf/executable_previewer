#!/bin/sh

set -euf

file="$1"
width="$2"
height="$3"
x="$4"
y="$5"
mode="${6:-preview}"

draw() {
  [ "$mode" = "preload" ] && exit 1
  kitten icat --silent --stdin no --transfer-mode file --scale-up \
    --place "${width}x${height}@${x}x${y}" "$1" < /dev/null > /dev/tty
  exit 1
}

hash() {
  if [ "$(uname)" = "Darwin" ]; then
    resolved="$1"
    [ -L "$1" ] && resolved="$(cd "$(dirname "$1")" && pwd -P)/$(basename "$1")"
    cache="$HOME/.cache/lf/$(stat -f '%N%i%T%z%B%m' -- "$resolved" | shasum -a 256 | cut -d' ' -f1).jpg"
  else
    cache="$HOME/.cache/lf/$(stat --printf '%n\0%i\0%F\0%s\0%W\0%Y' -- "$(readlink -f -- "$1")" | sha256sum | cut -d' ' -f1).jpg"
  fi
}

cache() {
  if ! [ -s "$cache" ]; then
    dir="$(dirname -- "$cache")"
    [ -d "$dir" ] || mkdir -p -- "$dir"
    "$@"
  fi
}

preview_image() {
  hash "$file"
  cache magick "$file"[0] -auto-orient -thumbnail 1280x1280\> "$cache"
  draw "$cache"
}

preview_video() {
  hash "$file"
  cache ffmpegthumbnailer -i "$file" -c jpg -s 1280 -f -o "$cache"
  draw "$cache"
}

preview_pdf() {
  hash "$file"
  cache gs -o "$cache" -sDEVICE=pngalpha -dLastPage=1 "$file" >/dev/null
  draw "$cache"
}

preview_text() {
  bat --color always "$file"
  exit 1
}

# Fast path: dispatch by extension to avoid spawning `file`.
ext="${file##*.}"
case "$(printf %s "$ext" | tr '[:upper:]' '[:lower:]')" in
  jpg|jpeg|png|gif|webp|bmp|tiff|tif|avif|heic|heif|jxl|svg|ico) preview_image ;;
  mp4|mkv|mov|avi|webm|wmv|flv|m4v|mpg|mpeg|ts|3gp|rmvb|m2p) preview_video ;;
  pdf) preview_pdf ;;
  txt|md|json|yaml|yml|toml|ini|conf|sh|py|rs|go|js|ts|tsx|jsx|c|cpp|h|hpp|rb|java|lua|vim|html|css|xml|log)
    preview_text ;;
esac

# Fallback: use `file` for unknown extensions.
case "$(file -Lb --mime-type -- "$file")" in
  image/*) preview_image ;;
  video/*) preview_video ;;
  application/pdf) preview_pdf ;;
  text/*) preview_text ;;
esac
